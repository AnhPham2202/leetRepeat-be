{
  "name": "leet-repeat-app",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run build:web && tsc",
    "start": "node dist/controller.js",
    "dev": "tsx watch src/controller.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.3",
    "concurrently": "^8.2.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
